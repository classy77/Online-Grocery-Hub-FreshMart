@model OrderViewModel
@{
    ViewData["Title"] = $"Order #{Model.OrderNumber}";
    Layout = "_AdminLayout";
    var deliveryStaff = ViewBag.DeliveryStaff as List<User>;
    var availableStatuses = ViewBag.AvailableStatuses as string[];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-bag-check me-2"></i>Order #@Model.OrderNumber</h2>
    <a asp-action="Orders" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to Orders
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Order Items -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">Order Items</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-center">Price</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@(item.ProductImage ?? "/images/products/placeholder.jpg")" alt="@item.ProductName" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                            <span class="ms-3">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="text-center">₹@item.UnitPrice.ToString("F2")</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">₹@item.Subtotal.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Subtotal:</td>
                                <td class="text-end">₹@Model.TotalAmount.ToString("F2")</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Discount:</td>
                                <td class="text-end text-success">-₹@Model.Discount.ToString("F2")</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Total:</td>
                                <td class="text-end fw-bold fs-5 text-success">₹@Model.FinalAmount.ToString("F2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Update Status -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">Update Order Status</h5>
            </div>
            <div class="card-body">
                <form asp-action="UpdateOrderStatus" method="post" class="row g-3">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="col-md-6">
                        <select name="status" class="form-select">
                            @foreach (var status in availableStatuses ?? new string[0])
                            {
                                <option value="@status" selected="@(Model.Status == status)">@status</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-arrow-clockwise me-2"></i>Update Status
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Assign Delivery Staff -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">Assign Delivery Staff</h5>
            </div>
            <div class="card-body">
                <form asp-action="AssignDeliveryStaff" method="post" class="row g-3">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="col-md-6">
                        <select name="deliveryStaffId" class="form-select">
                            <option value="">Select Delivery Staff</option>
                            @foreach (var staff in deliveryStaff ?? new List<User>())
                            {
                                <option value="@staff.Id">@staff.FullName (@staff.Email)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-person-check me-2"></i>Assign
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Order Info -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">Order Information</h5>
            </div>
            <div class="card-body">
                <p class="mb-2"><span class="text-muted">Order Number:</span> <span class="fw-semibold">@Model.OrderNumber</span></p>
                <p class="mb-2"><span class="text-muted">Status:</span> <span class="badge @GetStatusBadgeClass(Model.Status)">@Model.Status</span></p>
                <p class="mb-2"><span class="text-muted">Order Date:</span> @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                <p class="mb-0"><span class="text-muted">Last Updated:</span> @(Model.UpdatedAt?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")</p>
            </div>
        </div>

        <!-- Shipping Address -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">Shipping Address</h5>
            </div>
            <div class="card-body">
                <p class="mb-0">@Model.ShippingAddress</p>
            </div>
        </div>

        <!-- Payment Info -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">Payment Information</h5>
            </div>
            <div class="card-body">
                <p class="mb-2"><span class="text-muted">Method:</span> @(Model.Payment?.Method ?? "N/A")</p>
                <p class="mb-2"><span class="text-muted">Status:</span> <span class="badge bg-secondary">@(Model.Payment?.Status ?? "N/A")</span></p>
                <p class="mb-0"><span class="text-muted">Amount:</span> <span class="fw-bold text-success">₹@Model.FinalAmount.ToString("F2")</span></p>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Packed" => "bg-info",
            "OutForDelivery" => "bg-primary",
            "Delivered" => "bg-success",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
