@model List<User>
@{
    ViewData["Title"] = "Delivery Staff";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-person-badge me-2"></i>Delivery Staff Management</h2>
    <a asp-action="CreateDeliveryStaff" class="btn btn-success">
        <i class="bi bi-plus-circle me-2"></i>Add New Staff
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var staff in Model)
                        {
                            <tr>
                                <td>
                                    <span class="fw-semibold">@(staff.FullName ?? "N/A")</span>
                                </td>
                                <td>@staff.Email</td>
                                <td>@(staff.Phone ?? "N/A")</td>
                                <td>
                                    @if (staff.IsActive)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (staff.IsActive)
                                    {
                                        <form asp-action="DeactivateDeliveryStaff" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@staff.Id" />
                                            <button type="submit" class="btn btn-sm btn-warning" title="Deactivate">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="ActivateDeliveryStaff" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@staff.Id" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Activate">
                                                <i class="bi bi-play-circle"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                <p class="mb-0">No delivery staff members found. <a asp-action="CreateDeliveryStaff">Add one now</a></p>
            </div>
        }
    </div>
</div>
