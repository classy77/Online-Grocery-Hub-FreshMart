@{
    ViewData["Title"] = "Contact Us";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-6 mb-4">
            <h1 class="display-5 fw-bold mb-4">Get in Touch</h1>
            <p class="lead text-muted mb-4">Have questions or feedback? We'd love to hear from you.</p>
            
            <div class="mb-4">
                <h5><i class="bi bi-geo-alt-fill text-success me-2"></i>Address</h5>
                <p class="text-muted">123 Grocery Street, Main Market<br>City, State - 123456</p>
            </div>
            
            <div class="mb-4">
                <h5><i class="bi bi-telephone-fill text-success me-2"></i>Phone</h5>
                <p class="text-muted">+91 98765 43210<br>+91 98765 43211</p>
            </div>
            
            <div class="mb-4">
                <h5><i class="bi bi-envelope-fill text-success me-2"></i>Email</h5>
                <p class="text-muted">support@freshmart.com<br>info@freshmart.com</p>
            </div>
            
            <div class="mb-4">
                <h5><i class="bi bi-clock-fill text-success me-2"></i>Working Hours</h5>
                <p class="text-muted">Monday - Saturday: 8:00 AM - 10:00 PM<br>Sunday: 9:00 AM - 8:00 PM</p>
            </div>
        </div>
        
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Send us a Message</h4>
                    <form>
                        <div class="mb-3">
                            <label class="form-label">Your Name</label>
                            <input type="text" class="form-control" placeholder="Enter your name">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" placeholder="Enter your email">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input type="text" class="form-control" placeholder="Enter subject">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" rows="4" placeholder="Enter your message"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-send me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
