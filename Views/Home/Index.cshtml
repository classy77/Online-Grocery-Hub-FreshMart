@model List<ProductViewModel>
@{
    ViewData["Title"] = "FreshMart - Online Grocery Store";
    var categories = ViewBag.Categories as dynamic;
}

<!-- Hero Section -->
<section class="hero-section py-5" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 text-white">
                <h1 class="display-4 fw-bold mb-4">Fresh Groceries Delivered to Your Door</h1>
                <p class="lead mb-4">Shop from a wide range of fresh fruits, vegetables, dairy, and more. Get same-day delivery on all orders.</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg fw-semibold">
                        <i class="bi bi-basket me-2"></i>Shop Now
                    </a>
                    <a asp-controller="Home" asp-action="About" class="btn btn-outline-light btn-lg">
                        Learn More
                    </a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=600&h=400&fit=crop" alt="Fresh groceries" class="img-fluid rounded-4 shadow-lg">
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Shop by Category</h2>
        <div class="row g-4">
            @if (categories != null)
            {
                foreach (var category in categories)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id" class="text-decoration-none">
                            <div class="card category-card h-100 border-0 shadow-sm">
                                <div class="card-body text-center p-4">
                                    <div class="category-icon mb-3">
                                        @switch (category.Name.ToString().ToLower())
                                        {
                                            case "fruits":
                                                <i class="bi bi-apple fs-1 text-danger"></i>
                                                break;
                                            case "vegetables":
                                                <i class="bi bi-tree fs-1 text-success"></i>
                                                break;
                                            case "dairy":
                                                <i class="bi bi-cup-straw fs-1 text-primary"></i>
                                                break;
                                            case "bakery":
                                                <i class="bi bi-bread-slice fs-1 text-warning"></i>
                                                break;
                                            case "beverages":
                                                <i class="bi bi-cup-hot fs-1 text-info"></i>
                                                break;
                                            case "snacks":
                                                <i class="bi bi-cookie fs-1 text-secondary"></i>
                                                break;
                                            default:
                                                <i class="bi bi-box fs-1 text-success"></i>
                                                break;
                                        }
                                    </div>
                                    <h5 class="card-title fw-semibold text-dark">@category.Name</h5>
                                    <p class="text-muted small mb-0">@category.ProductCount products</p>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Featured Products Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="fw-bold mb-0">Featured Products</h2>
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success">View All <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 border-0 shadow-sm">
                        <div class="position-relative">
                            <img src="@(product.ImageUrl ?? "/images/products/placeholder.jpg")" class="card-img-top" alt="@product.Name" style="height: 180px; object-fit: cover;">
                            @if (product.Stock < 10)
                            {
                                <span class="badge bg-danger position-absolute top-0 end-0 m-2">Low Stock</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <small class="text-muted text-uppercase">@product.CategoryName</small>
                            <h6 class="card-title fw-semibold">@product.Name</h6>
                            <p class="text-muted small flex-grow-1">@(product.Description?.Length > 50 ? product.Description.Substring(0, 50) + "..." : product.Description)</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="h5 mb-0 text-success fw-bold">₹@product.Price.ToString("F2")</span>
                                <span class="text-muted small">@product.Unit</span>
                            </div>
                            <button class="btn btn-success w-100 mt-3 add-to-cart" data-product-id="@product.Id">
                                <i class="bi bi-cart-plus me-2"></i>Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-truck fs-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold">Free Delivery</h5>
                    <p class="text-muted">Free delivery on orders above ₹500. Same-day delivery available.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-shield-check fs-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold">Quality Guaranteed</h5>
                    <p class="text-muted">100% fresh and quality products. Easy returns if not satisfied.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-headset fs-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold">24/7 Support</h5>
                    <p class="text-muted">Our customer support team is always ready to help you.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.add-to-cart').click(function() {
                var productId = $(this).data('product-id');
                var button = $(this);
                
                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { productId: productId, quantity: 1 },
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    success: function(response) {
                        if (response.success) {
                            updateCartCount(response.cartCount);
                            showToast('Success', response.message);
                        } else {
                            showToast('Error', response.message);
                        }
                    },
                    error: function() {
                        showToast('Error', 'Failed to add item to cart');
                    }
                });
            });
            
            function updateCartCount(count) {
                $('#cart-count').text(count).show();
            }
            
            function showToast(title, message) {
                // Simple alert for now - can be enhanced with toast notifications
                alert(message);
            }
        });
    </script>
}
