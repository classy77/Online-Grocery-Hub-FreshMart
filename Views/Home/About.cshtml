@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col-lg-6">
            <h1 class="display-5 fw-bold mb-4">About FreshMart</h1>
            <p class="lead text-muted">Your trusted partner for fresh groceries since 2020.</p>
            <p>FreshMart is an online grocery store committed to providing high-quality fresh produce, dairy, bakery items, and household essentials directly to your doorstep. We work directly with farmers and trusted suppliers to ensure you get the freshest products at competitive prices.</p>
            <p>Our mission is to make grocery shopping convenient, affordable, and enjoyable for everyone. With our user-friendly platform, you can browse thousands of products, place orders in minutes, and track your delivery in real-time.</p>
        </div>
        <div class="col-lg-6">
            <img src="https://images.unsplash.com/photo-1534723452862-4c874018d66d?w=600&h=400&fit=crop" alt="About FreshMart" class="img-fluid rounded-4 shadow">
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="display-4 fw-bold text-success mb-2">50K+</div>
                <h5>Happy Customers</h5>
                <p class="text-muted mb-0">Trust us for their daily grocery needs</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="display-4 fw-bold text-success mb-2">5000+</div>
                <h5>Products</h5>
                <p class="text-muted mb-0">Wide range of quality products</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <div class="display-4 fw-bold text-success mb-2">100+</div>
                <h5>Daily Orders</h5>
                <p class="text-muted mb-0">Delivered across the city</p>
            </div>
        </div>
    </div>

    <div class="text-center">
        <h2 class="fw-bold mb-4">Our Values</h2>
        <div class="row g-4">
            <div class="col-md-3">
                <i class="bi bi-heart-fill fs-1 text-danger mb-3"></i>
                <h5>Customer First</h5>
                <p class="text-muted">Your satisfaction is our priority</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-leaf-fill fs-1 text-success mb-3"></i>
                <h5>Fresh & Organic</h5>
                <p class="text-muted">Only the best quality products</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-clock-fill fs-1 text-primary mb-3"></i>
                <h5>On-Time Delivery</h5>
                <p class="text-muted">We value your time</p>
            </div>
            <div class="col-md-3">
                <i class="bi bi-currency-rupee fs-1 text-warning mb-3"></i>
                <h5>Best Prices</h5>
                <p class="text-muted">Competitive pricing guaranteed</p>
            </div>
        </div>
    </div>
</div>
