@model DeliveryDashboardViewModel
@{
    ViewData["Title"] = "My Deliveries";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-truck me-2"></i>My Deliveries</h2>

    <!-- Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body text-center">
                    <i class="bi bi-bag display-4"></i>
                    <h4 class="mt-2">@Model.AssignedOrders</h4>
                    <p class="mb-0">Total Assigned</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-warning text-dark">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass display-4"></i>
                    <h4 class="mt-2">@Model.PendingDeliveries</h4>
                    <p class="mb-0">Pending</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle display-4"></i>
                    <h4 class="mt-2">@Model.CompletedToday</h4>
                    <p class="mb-0">Completed Today</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders List -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0 fw-bold">Assigned Orders</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Orders.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Order #</th>
                                <th>Customer</th>
                                <th>Address</th>
                                <th>Items</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td><span class="fw-semibold">@order.OrderNumber</span></td>
                                    <td>
                                        @order.CustomerName<br>
                                        <small class="text-muted">@order.CustomerPhone</small>
                                    </td>
                                    <td><small>@order.Address</small></td>
                                    <td>
                                        @foreach (var item in order.Items.Take(2))
                                        {
                                            <small class="d-block">@item</small>
                                        }
                                        @if (order.Items.Count > 2)
                                        {
                                            <small class="text-muted">+@(order.Items.Count - 2) more</small>
                                        }
                                    </td>
                                    <td><span class="badge @GetStatusBadgeClass(order.Status)">@order.Status</span></td>
                                    <td>
                                        <a asp-action="OrderDetails" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-truck display-1 text-muted"></i>
                    <h4 class="mt-3">No deliveries assigned</h4>
                    <p class="text-muted">You don't have any assigned deliveries yet.</p>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Scheduled" => "bg-secondary",
            "Assigned" => "bg-info",
            "PickedUp" => "bg-warning",
            "OutForDelivery" => "bg-primary",
            "Delivered" => "bg-success",
            "Failed" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
