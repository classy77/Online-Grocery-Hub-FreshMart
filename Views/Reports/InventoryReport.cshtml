@model dynamic
@{
    ViewData["Title"] = "Inventory Report";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-box-seam me-2"></i>Inventory Report</h2>
    <a href="/Reports/ExportInventory" class="btn btn-outline-success">
        <i class="bi bi-download me-2"></i>Export
    </a>
</div>

<!-- Summary -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm bg-warning text-dark">
            <div class="card-body text-center">
                <i class="bi bi-exclamation-triangle display-4"></i>
                <h4 class="mt-2">@ViewBag.LowStockCount</h4>
                <p class="mb-0">Low Stock Products</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm bg-success text-white">
            <div class="card-body text-center">
                <i class="bi bi-currency-rupee display-4"></i>
                <h4 class="mt-2">₹@ViewBag.TotalStockValue.ToString("F0")</h4>
                <p class="mb-0">Total Stock Value</p>
            </div>
        </div>
    </div>
</div>

<!-- Inventory Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-light">
        <h5 class="mb-0 fw-bold">Product Inventory</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th class="text-center">Stock</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Stock Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td><span class="fw-semibold">@product.Name</span></td>
                            <td>@product.CategoryName</td>
                            <td class="text-center">
                                @if (product.Stock < 10)
                                {
                                    <span class="badge bg-danger">@product.Stock</span>
                                }
                                else if (product.Stock < 50)
                                {
                                    <span class="badge bg-warning text-dark">@product.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@product.Stock</span>
                                }
                            </td>
                            <td class="text-end">₹@(((decimal)product.PriceCents / 100).ToString("F2"))</td>
                            <td class="text-end fw-semibold">₹@product.StockValue.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
