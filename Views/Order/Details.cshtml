@model OrderViewModel
@{
    ViewData["Title"] = $"Order #{Model.OrderNumber}";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">My Orders</a></li>
            <li class="breadcrumb-item active">Order #@Model.OrderNumber</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Order Info -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold">Order #@Model.OrderNumber</h5>
                        <small class="text-muted">Placed on @Model.CreatedAt.ToString("MMMM dd, yyyy at hh:mm tt")</small>
                    </div>
                    <span class="badge @GetStatusBadgeClass(Model.Status) fs-6">@Model.Status</span>
                </div>
                <div class="card-body">
                    <!-- Order Timeline -->
                    <div class="order-timeline mb-4">
                        <div class="d-flex justify-content-between position-relative">
                            <div class="timeline-line"></div>
                            @{
                                var statuses = new[] { "Pending", "Packed", "OutForDelivery", "Delivered" };
                                var currentIndex = Array.IndexOf(statuses, Model.Status);
                                if (Model.Status == "Cancelled") currentIndex = -1;
                            }
                            @foreach (var status in statuses)
                            {
                                var index = Array.IndexOf(statuses, status);
                                var isCompleted = index <= currentIndex;
                                var isCurrent = index == currentIndex;
                                <div class="timeline-step text-center @(isCompleted ? "completed" : "") @(isCurrent ? "current" : "")">
                                    <div class="timeline-icon">
                                        <i class="bi @GetTimelineIcon(status)"></i>
                                    </div>
                                    <small class="d-block mt-1">@status.Replace("OutForDelivery", "Out for Delivery")</small>
                                </div>
                            }
                        </div>
                    </div>

                    <h6 class="fw-semibold mb-3">Order Items</h6>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Price</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@(item.ProductImage ?? "/images/products/placeholder.jpg")" alt="@item.ProductName" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                                                <span class="ms-3">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="text-center">₹@item.UnitPrice.ToString("F2")</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">₹@item.Subtotal.ToString("F2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Order Summary</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span>₹@Model.TotalAmount.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Discount</span>
                        <span class="text-success">-₹@Model.Discount.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Delivery</span>
                        <span class="text-success">@(Model.TotalAmount >= 500 ? "Free" : "₹50.00")</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold">Total</span>
                        <span class="fw-bold fs-5 text-success">₹@Model.FinalAmount.ToString("F2")</span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-geo-alt me-2"></i>Delivery Address</h6>
                    <p class="mb-0">@Model.ShippingAddress</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-credit-card me-2"></i>Payment Information</h6>
                    <p class="mb-1"><span class="text-muted">Method:</span> @(Model.Payment?.Method ?? "N/A")</p>
                    <p class="mb-1"><span class="text-muted">Status:</span> <span class="badge bg-secondary">@(Model.Payment?.Status ?? "N/A")</span></p>
                    @if (Model.Payment?.PaidAt != null)
                    {
                        <p class="mb-0"><span class="text-muted">Paid on:</span> @Model.Payment.PaidAt?.ToString("MMM dd, yyyy")</p>
                    }
                </div>
            </div>

            @if (Model.Status == "Pending")
            {
                <form asp-action="CancelOrder" method="post" class="mt-3">
                    <input type="hidden" name="id" value="@Model.OrderId" />
                    <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Are you sure you want to cancel this order?')">
                        <i class="bi bi-x-circle me-2"></i>Cancel Order
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Packed" => "bg-info",
            "OutForDelivery" => "bg-primary",
            "Delivered" => "bg-success",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    string GetTimelineIcon(string status)
    {
        return status switch
        {
            "Pending" => "bi-hourglass",
            "Packed" => "bi-box-seam",
            "OutForDelivery" => "bi-truck",
            "Delivered" => "bi-check-circle",
            _ => "bi-circle"
        };
    }
}

@section Styles {
    <style>
        .order-timeline {
            padding: 20px 0;
        }
        .timeline-line {
            position: absolute;
            top: 20px;
            left: 10%;
            right: 10%;
            height: 3px;
            background: #e9ecef;
            z-index: 0;
        }
        .timeline-step {
            position: relative;
            z-index: 1;
            flex: 1;
        }
        .timeline-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            color: #6c757d;
        }
        .timeline-step.completed .timeline-icon {
            background: #28a745;
            color: white;
        }
        .timeline-step.current .timeline-icon {
            background: #ffc107;
            color: #000;
        }
    </style>
}
