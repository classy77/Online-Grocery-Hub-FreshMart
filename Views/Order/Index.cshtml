@model List<OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-bag-check me-2"></i>My Orders</h2>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-12 mb-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <div>
                                <span class="fw-bold">Order #@order.OrderNumber</span>
                                <span class="text-muted ms-3"><i class="bi bi-calendar me-1"></i>@order.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            <span class="badge @GetStatusBadgeClass(order.Status)">@order.Status</span>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-8">
                                    <h6 class="fw-semibold mb-3">Items:</h6>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var item in order.Items.Take(3))
                                        {
                                            <div class="d-flex align-items-center bg-light rounded p-2">
                                                <img src="@(item.ProductImage ?? "/images/products/placeholder.jpg")" alt="@item.ProductName" class="rounded" style="width: 40px; height: 40px; object-fit: cover;">
                                                <div class="ms-2">
                                                    <small class="fw-semibold d-block">@item.ProductName</small>
                                                    <small class="text-muted">x@(item.Quantity)</small>
                                                </div>
                                            </div>
                                        }
                                        @if (order.Items.Count > 3)
                                        {
                                            <div class="d-flex align-items-center bg-light rounded p-2">
                                                <small class="text-muted">+@(order.Items.Count - 3) more</small>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                    <p class="mb-1"><span class="text-muted">Total:</span> <span class="fw-bold fs-5 text-success">₹@order.FinalAmount.ToString("F2")</span></p>
                                    <p class="mb-2"><span class="text-muted">Payment:</span> <span class="badge bg-secondary">@(order.Payment?.Method ?? "N/A")</span></p>
                                    <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-outline-success btn-sm">
                                        <i class="bi bi-eye me-1"></i>View Details
                                    </a>
                                    @if (order.Status == "Pending")
                                    {
                                        <form asp-action="CancelOrder" method="post" class="d-inline ms-2">
                                            <input type="hidden" name="id" value="@order.OrderId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to cancel this order?')">
                                                <i class="bi bi-x-circle me-1"></i>Cancel
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x display-1 text-muted"></i>
            <h3 class="mt-4">No orders yet</h3>
            <p class="text-muted">You haven't placed any orders yet.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-success btn-lg mt-3">
                <i class="bi bi-shop me-2"></i>Start Shopping
            </a>
        </div>
    }
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Packed" => "bg-info",
            "OutForDelivery" => "bg-primary",
            "Delivered" => "bg-success",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
