@model List<ProductViewModel>
@{
    ViewData["Title"] = "Products";
    var categories = ViewBag.Categories as dynamic;
    var selectedCategory = ViewBag.SelectedCategory as dynamic;
}

<div class="container py-4">
    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-lg-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="bi bi-funnel me-2"></i>Filters</h5>
                    
                    <!-- Categories -->
                    <div class="mb-4">
                        <h6 class="fw-semibold mb-2">Categories</h6>
                        <div class="list-group list-group-flush">
                            <a asp-action="Index" class="list-group-item list-group-item-action @(selectedCategory == null ? "active" : "")">
                                All Categories
                            </a>
                            @if (categories != null)
                            {
                                foreach (var category in categories)
                                {
                                    <a asp-action="Index" asp-route-categoryId="@category.Id" 
                                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(selectedCategory?.Id == category.Id ? "active" : "")">
                                        @category.Name
                                        <span class="badge bg-secondary rounded-pill">@category.ProductCount</span>
                                    </a>
                                }
                            }
                        </div>
                    </div>

                    <!-- Price Filter -->
                    <div class="mb-4">
                        <h6 class="fw-semibold mb-2">Price Range</h6>
                        <form asp-action="Index" method="get">
                            @if (selectedCategory != null)
                            {
                                <input type="hidden" name="categoryId" value="@selectedCategory.Id" />
                            }
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" name="minPrice" class="form-control" placeholder="Min" value="@ViewBag.MinPrice">
                                </div>
                                <div class="col-6">
                                    <input type="number" name="maxPrice" class="form-control" placeholder="Max" value="@ViewBag.MaxPrice">
                                </div>
                            </div>
                            <button type="submit" class="btn btn-outline-success btn-sm w-100 mt-2">Apply</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-0">@(selectedCategory?.Name ?? "All Products")</h2>
                    <p class="text-muted mb-0">@Model.Count products found</p>
                </div>
                <div class="d-flex align-items-center">
                    <label class="me-2">Sort by:</label>
                    <select class="form-select form-select-sm" style="width: 150px;" onchange="window.location.href=this.value">
                        <option value="@Url.Action("Index", new { categoryId = selectedCategory?.Id, search = ViewBag.SearchTerm, sort = "", minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice })" selected="@(ViewBag.SortOrder == null)">Default</option>
                        <option value="@Url.Action("Index", new { categoryId = selectedCategory?.Id, search = ViewBag.SearchTerm, sort = "price_asc", minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice })" selected="@(ViewBag.SortOrder == "price_asc")">Price: Low to High</option>
                        <option value="@Url.Action("Index", new { categoryId = selectedCategory?.Id, search = ViewBag.SearchTerm, sort = "price_desc", minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice })" selected="@(ViewBag.SortOrder == "price_desc")">Price: High to Low</option>
                        <option value="@Url.Action("Index", new { categoryId = selectedCategory?.Id, search = ViewBag.SearchTerm, sort = "name_asc", minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice })" selected="@(ViewBag.SortOrder == "name_asc")">Name: A-Z</option>
                    </select>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <div class="alert alert-info">
                    <i class="bi bi-search me-2"></i>Search results for: <strong>@ViewBag.SearchTerm</strong>
                    <a asp-action="Index" class="float-end"><i class="bi bi-x-circle"></i></a>
                </div>
            }

            <!-- Products -->
            @if (Model.Any())
            {
                <div class="row g-4">
                    @foreach (var product in Model)
                    {
                        <div class="col-6 col-md-4">
                            <div class="card product-card h-100 border-0 shadow-sm">
                                <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                                    <div class="position-relative">
                                        <img src="@(product.ImageUrl ?? "/images/products/placeholder.jpg")" class="card-img-top" alt="@product.Name" style="height: 180px; object-fit: cover;">
                                        @if (product.Stock < 10)
                                        {
                                            <span class="badge bg-danger position-absolute top-0 end-0 m-2">Low Stock</span>
                                        }
                                    </div>
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <small class="text-muted text-uppercase">@product.CategoryName</small>
                                    <a asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                                        <h6 class="card-title fw-semibold text-dark">@product.Name</h6>
                                    </a>
                                    <p class="text-muted small flex-grow-1">@(product.Description?.Length > 40 ? product.Description.Substring(0, 40) + "..." : product.Description)</p>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="h5 mb-0 text-success fw-bold">₹@product.Price.ToString("F2")</span>
                                        <span class="text-muted small">@product.Unit</span>
                                    </div>
                                    <button class="btn btn-success btn-sm w-100 mt-3 add-to-cart" data-product-id="@product.Id">
                                        <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-search display-1 text-muted"></i>
                    <h4 class="mt-3">No products found</h4>
                    <p class="text-muted">Try adjusting your filters or search terms</p>
                    <a asp-action="Index" class="btn btn-success">View All Products</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.add-to-cart').click(function(e) {
                e.preventDefault();
                e.stopPropagation();
                var productId = $(this).data('product-id');
                var button = $(this);
                
                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { productId: productId, quantity: 1 },
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('Failed to add item to cart');
                    }
                });
            });
        });
    </script>
}
